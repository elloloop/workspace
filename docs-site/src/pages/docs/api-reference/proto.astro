---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import { Code } from "astro-expressive-code/components";
// The proto is the source of truth for the contract. We render it verbatim,
// syntax-highlighted, so field numbers, oneofs, and comments are all visible —
// the things the OpenAPI/Scalar view (a HTTP/JSON projection) necessarily
// drops. `make protodoc` keeps this copy in sync with proto/workspace/v1.
import protoSrc from "../../../data/workspace-v1.proto?raw";

const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
const ghBase = "https://github.com/elloloop/workspace";

const services = [
  {
    name: "WorkspaceService",
    summary: "Personal & team workspaces, membership, and token invitations.",
    rpcs: [
      "CreateWorkspace", "GetWorkspace", "ListWorkspaces", "UpdateWorkspace", "DeleteWorkspace",
      "AddMember", "UpdateMemberRole", "RemoveMember", "ListMembers",
      "CreateInvitation", "AcceptInvitation", "ListInvitations", "RevokeInvitation",
    ],
  },
  {
    name: "GroupService",
    summary: "Reusable, nestable groups — separate from workspaces.",
    rpcs: ["CreateGroup", "GetGroup", "ListGroups", "DeleteGroup", "AddGroupMember", "RemoveGroupMember", "ListGroupMembers"],
  },
  {
    name: "AuthzService",
    summary: "The Zanzibar relation-tuple engine: Write/Read/Check/Expand.",
    rpcs: ["WriteRelationTuples", "ReadRelationTuples", "Check", "Expand"],
  },
];
---

<DocsLayout title="Proto Reference">
  <h1>Proto Reference</h1>
  <p>
    The <strong>proto is the source of truth</strong> for the contract. The
    <a href={`${base}api`}>Live API Reference</a> (Scalar) documents the
    HTTP/JSON projection with a try-it console; this page shows the
    <code>workspace.v1</code> protobuf definition itself — services, messages,
    field numbers, <code>oneof</code>s, enums, and comments — which is what you
    work from when generating a gRPC/Connect client.
  </p>
  <ul>
    <li>
      Source:
      <a href={`${ghBase}/blob/main/proto/workspace/v1/workspace.proto`}><code>proto/workspace/v1/workspace.proto</code></a>
    </li>
    <li>
      Download: <a href={`${base}proto/workspace-v1.proto`}><code>workspace-v1.proto</code></a>
    </li>
  </ul>

  <h2>Services</h2>
  <table>
    <thead>
      <tr><th>Service</th><th>RPCs</th></tr>
    </thead>
    <tbody>
      {services.map((s) => (
        <tr>
          <td>
            <code>workspace.v1.{s.name}</code>
            <br /><span style="opacity:0.7">{s.summary}</span>
          </td>
          <td>{s.rpcs.map((r) => <span><code>{r}</code> </span>)}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>Generate a client</h2>
  <p>
    Connect/gRPC clients are generated from this proto. With
    <a href="https://buf.build">buf</a> you can generate locally from the source
    tree, or — once the module is published to the Buf Schema Registry — pull it
    remotely without vendoring the proto:
  </p>
  <Code
    code={`# from a checkout of the repo
buf generate

# or, against the published BSR module (no local proto needed)
buf generate buf.build/elloloop/workspace`}
    lang="bash"
    title="buf generate"
  />
  <p>
    The Go client is committed under
    <a href={`${ghBase}/tree/main/gen/go/workspace/v1`}><code>gen/go/workspace/v1</code></a>
    (with the Connect bindings in <code>workspacev1connect</code>).
  </p>

  <h2>Full definition</h2>
  <p>The complete <code>workspace.v1</code> schema, verbatim:</p>
  <Code code={protoSrc} lang="proto" title="proto/workspace/v1/workspace.proto" />
</DocsLayout>
